# Resend (contact form emails) – required for /api/send-email
# Get your API key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: override where emails are sent from/to (defaults below work with Resend onboarding)
# From must be a verified domain or onboarding@resend.dev
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_TO_EMAIL=delivered@resend.dev

# Optional: frontend only – set if your API is on a different origin (e.g. local dev proxy)
# VITE_API_URL=
